# ── База данных: Supabase Postgres ───────────────────────────
# Supabase → Project Settings → Database → Connection string → вкладка
# "Connection pooler" (Transaction mode, порт 6543). Она рассчитана на
# serverless (Vercel). Пароль — из того же экрана.
# Локально подойдёт обычный Postgres:
#   postgres://postgres@localhost:5432/agrigator
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# ── Режим денежно-доверительных операций ─────────────────────
# 'manual' — оператор подтверждает оплату/выплату/верификацию руками
#            (через /admin); уведомления летят в Telegram.
# 'auto'   — тот же код, но переходы дёргают вебхуки/кроны.
PAYMENT_MODE="manual"

# ── Внешние сервисы (на старте не обязательны) ───────────────
# Kaspi Pay / Merchant API (для PAYMENT_MODE=auto)
KASPI_MERCHANT_ID=""
KASPI_API_KEY=""
# Telegram-бот для пингов оператору
TELEGRAM_BOT_TOKEN=""
TELEGRAM_OPERATOR_CHAT_ID=""

# ── Фоновые задачи (Vercel Cron) ─────────────────────────────
# Секрет: Vercel шлёт его в Authorization при вызове /api/cron/*.
CRON_SECRET=""

# ── Supabase Storage (загрузка score reports) ────────────────
# Создай ПУБЛИЧНЫЙ бакет "reports" в Supabase → Storage.
# SUPABASE_URL — https://<ref>.supabase.co (Project Settings → API).
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="reports"

# ── Аналитика PostHog (опционально) ──────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
