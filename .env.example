# ── База данных ───────────────────────────────────────────────
# Dev: SQLite (никаких внешних сервисов, заводится сразу).
# Prod: Supabase Postgres — поменять provider в prisma/schema.prisma на
#       "postgresql" и подставить сюда connection string.
DATABASE_URL="file:./prisma/dev.db"

# ── Режим денежно-доверительных операций ─────────────────────
# 'manual' — оператор подтверждает оплату/выплату/верификацию руками
#            (через /admin), уведомления летят в Telegram.
# 'auto'   — тот же код, но переходы дёргают вебхуки/кроны.
# Переключение = смена флага, без рефактора (см. lib/payments).
PAYMENT_MODE="manual"
VERIFICATION_MODE="manual"
PAYOUT_MODE="manual"

# ── Сессии ────────────────────────────────────────────────────
# Секрет для подписи сессионных токенов. В проде заменить на Supabase Auth.
AUTH_SECRET="dev-secret-change-me"

# ── Внешние сервисы (на старте не обязательны) ────────────────
# Kaspi Pay / Merchant API
KASPI_MERCHANT_ID=""
KASPI_API_KEY=""
# Telegram-бот для пингов оператору
TELEGRAM_BOT_TOKEN=""
TELEGRAM_OPERATOR_CHAT_ID=""
